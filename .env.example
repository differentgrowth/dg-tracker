# Postgres connection string. The local docker-compose setup at
# docker/docker-compose.yml exposes a database that matches this URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dg-tracker_dev

# Better Auth signing secret. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me

# Public URL the app is reachable at. Used by Better Auth for cookies and
# callback URLs. Update for preview/production deployments.
BETTER_AUTH_URL=http://localhost:3000

# Public app URL used to build absolute redirect URIs for Google OAuth.
# Should match BETTER_AUTH_URL in most cases.
APP_URL=http://localhost:3000

# Google OAuth credentials for Search Console integration.
# Create a Web Application OAuth client in Google Cloud Console and add the
# redirect URI below to its authorized list. Required scope:
#   https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/callback

# 32-byte key (base64-encoded) used to encrypt Google OAuth tokens at rest.
# Generate with:
#   openssl rand -base64 32
GSC_TOKEN_ENCRYPTION_KEY=
