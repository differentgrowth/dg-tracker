// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth Models (better-auth)
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("member") // admin | member
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ============================================
// Core Models
// ============================================

model Client {
  id            String    @id @default(cuid())
  name          String
  primaryDomain String?
  gscProperty   String? // e.g. "sc-domain:example.com" or "https://example.com"
  status        String    @default("active") // active | archived
  notes         String?
  assignedTo    String? // team member email or name
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  domains       Domain[]
  reports       Report[]
  gscConnection GscConnection?

  @@index([status])
  @@map("clients")
}

model Domain {
  id                String   @id @default(cuid())
  url               String
  notes             String?
  scheduledSyncDays Int      @default(1)
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  keywords Keyword[]

  @@index([clientId])
  @@map("domains")
}

model Keyword {
  id             String    @id @default(cuid())
  term           String
  targetUrl      String? // canonical URL the keyword should rank for
  targetPosition Int? // e.g. 3 (top 3 goal)
  priority       String? // low | medium | high | critical
  status         String    @default("active") // active | archived
  tags           String[] // flexible tagging (Postgres array)
  searchVolume   Int? // optional - for future imports
  difficulty     Int? // 0-100
  category       String? // e.g. "informational", "commercial", "branded"
  notes          String?
  lastCheckedAt  DateTime?
  domainId       String
  domain         Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  snapshots RankingSnapshot[]

  @@unique([domainId, term])
  @@index([domainId])
  @@index([term])
  @@index([status])
  @@index([priority])
  @@index([lastCheckedAt])
  @@map("keywords")
}

model RankingSnapshot {
  id              String   @id @default(cuid())
  keywordId       String
  keyword         Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  date            DateTime
  position        Int? // exact rank from a SERP provider
  avgPosition     Float? // average position from GSC (preserves fractional value)
  url             String?
  impressions     Int?
  clicks          Int?
  ctr             Float? // click-through rate
  source          String // "gsc" | "serp"
  featuredSnippet Boolean?
  aiOverview      Boolean? // future-proof for AI Overviews
  notes           String?
  createdAt       DateTime @default(now())

  @@unique([keywordId, date, source])
  @@index([keywordId, date])
  @@index([date])
  @@index([source])
  @@map("ranking_snapshots")
}

// ============================================
// Optional but recommended for growth
// ============================================

model Report {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  fileUrl     String? // link to generated PDF/report
  generatedBy String? // user who triggered it
  createdAt   DateTime @default(now())

  @@index([clientId, periodStart])
  @@map("reports")
}

// ============================================
// Integration: Google Search Console
// ============================================

model GscConnection {
  id                   String    @id @default(cuid())
  clientId             String    @unique
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  googleAccountEmail   String
  googleAccountSubject String // Google "sub" claim — stable user id
  gscSiteUrl           String // canonical GSC property, e.g. "sc-domain:example.com"
  scopes               String[] // granted scopes from Google
  accessTokenCipher    String // AES-256-GCM ciphertext (base64 iv.tag.ct)
  refreshTokenCipher   String // AES-256-GCM ciphertext (base64 iv.tag.ct)
  accessTokenExpiresAt DateTime
  lastSyncedAt         DateTime?
  lastSyncError        String?
  connectedByUserId    String // user who completed the OAuth flow
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([googleAccountSubject])
  @@map("gsc_connections")
}
